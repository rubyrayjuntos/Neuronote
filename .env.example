# NeuroNote AI Provider Configuration
# Copy this file to .env and fill in your credentials

# ==============================================================================
# PROVIDER SELECTION
# ==============================================================================
# Choose your AI provider: 'gemini' | 'bedrock-claude' | 'bedrock-llama' | 'bedrock-mistral'
VITE_AI_PROVIDER=bedrock-claude

# ==============================================================================
# GOOGLE GEMINI (if using VITE_AI_PROVIDER=gemini)
# ==============================================================================
# Get your API key at: https://aistudio.google.com/app/apikey
# VITE_API_KEY=your-gemini-api-key-here

# ==============================================================================
# AWS BEDROCK (if using VITE_AI_PROVIDER=bedrock-*)
# ==============================================================================
# Create an IAM user with AmazonBedrockFullAccess policy
# Get credentials from: AWS Console → IAM → Users → Security credentials
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your-aws-access-key-id
VITE_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ==============================================================================
# AVAILABLE BEDROCK MODELS
# ==============================================================================
# bedrock-claude: Claude 3 Sonnet (anthropic.claude-3-sonnet-20240229-v1:0)
#   - Best for self-correction, 200K context window
#   - Requires: Model access enabled in AWS Bedrock console
#
# bedrock-llama: Llama 3 70B (meta.llama3-70b-instruct-v1:0)
#   - Open weights, good for general tasks
#   - Requires: Model access enabled in AWS Bedrock console
#
# bedrock-mistral: Mistral Large (mistral.mistral-large-2402-v1:0)
#   - Code optimized, efficient
#   - Requires: Model access enabled in AWS Bedrock console

# ==============================================================================
# IMPORTANT: AWS BEDROCK SETUP
# ==============================================================================
# 1. Sign in to AWS Console
# 2. Go to Amazon Bedrock → Model access
# 3. Request access to Claude 3 Sonnet (or your chosen model)
# 4. Wait for access to be granted (usually instant for Claude)
# 5. Create IAM user with programmatic access and AmazonBedrockFullAccess
# 6. Copy access keys to this file
